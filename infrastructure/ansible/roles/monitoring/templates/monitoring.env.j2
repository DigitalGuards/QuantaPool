# Monitoring stack environment - generated by Ansible
# {{ ansible_date_time.iso8601 }}

# Grafana
GRAFANA_ADMIN_PASSWORD={{ grafana_admin_password }}
GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}
GF_USERS_ALLOW_SIGN_UP=false

# Validator targets
PRIMARY_VALIDATOR_HOST={{ hostvars[groups['primary'][0]]['private_ip'] }}
{% if 'backup' in groups and groups['backup'] | length > 0 %}
BACKUP_VALIDATOR_HOST={{ hostvars[groups['backup'][0]]['private_ip'] }}
{% else %}
BACKUP_VALIDATOR_HOST=
{% endif %}

# QRL RPC
QRL_RPC_URL={{ qrl_rpc_url }}

# Contract addresses (v2.2)
STQRL_ADDRESS={{ stqrl_address | default('QA2f23388d1e3986416A36d2Ef113850D6900b69C') }}
DEPOSIT_POOL_ADDRESS={{ deposit_pool_address | default('Q109d7C528a67b80eb638D4C85e7C4545ef9Bb9aC') }}
VALIDATOR_MANAGER_ADDRESS={{ validator_manager_address | default('QA5b6e85B7713670589e4eAf2F039380Ec2792c8C') }}

# Alerting (optional)
{% if discord_webhook_url is defined and discord_webhook_url != '' %}
DISCORD_WEBHOOK_URL={{ discord_webhook_url }}
{% endif %}
{% if telegram_bot_token is defined and telegram_bot_token != '' %}
TELEGRAM_BOT_TOKEN={{ telegram_bot_token }}
TELEGRAM_CHAT_ID={{ telegram_chat_id }}
{% endif %}
