# QuantaPool Monitoring Stack Configuration
# Copy this file to .env and fill in your values

# ==============================================
# GRAFANA CONFIGURATION
# ==============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=__CHANGE_ME_TO_A_SECURE_RANDOM_PASSWORD__
GRAFANA_ROOT_URL=http://localhost:3000

# ==============================================
# VALIDATOR NODE (where the QRL execution + beacon clients run)
# ==============================================
# IP address or hostname of your validator server
VALIDATOR_HOST=192.168.1.100

# ==============================================
# QRL RPC CONFIGURATION
# ==============================================
QRL_RPC_URL=https://qrlwallet.com/api/qrl-rpc/testnet

# ==============================================
# CONTRACT ADDRESSES (v2 testnet deployment, chainId 1337)
# ==============================================
# QRL uses Q-prefix format for addresses. See config/testnet-hyperion.json for the
# source of truth; override here only if you deploy your own instance.
STQRL_ADDRESS=Q09046968aF19E745F4aBa7A9fa5CD946b4E981DB
DEPOSIT_POOL_ADDRESS=Q38F73cb87c60d365fdFA7abF0e534fc1a9D5F9B9
VALIDATOR_MANAGER_ADDRESS=Q1b083D7Dc47212DcBc4595249D9384Fa16cE6FC5

# ==============================================
# CONTRACT EXPORTER SETTINGS
# ==============================================
# How often to query contract state (milliseconds)
CONTRACT_SCRAPE_INTERVAL=30000
# How often to poll for contract events (milliseconds) - QRL has 60s block time
EVENT_POLL_INTERVAL_MS=60000

# ==============================================
# ALERTING - DISCORD
# ==============================================
# Create a webhook in your Discord server:
# Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ==============================================
# ALERTING - TELEGRAM (Optional)
# ==============================================
# Create a bot via @BotFather and get your chat ID
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=-1001234567890
